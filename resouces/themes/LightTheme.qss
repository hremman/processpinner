/* Основные цвета светлой темы */
QMainWindow, QWidget {
    background-color: #f0f0f0;
    color: #000000;
    font-family: 'Segoe UI', 'Arial', sans-serif;
}

/* Вкладки */
QTabWidget::pane {
    border: 1px solid #d0d0d0;
    background-color: #ffffff;
}

QTabBar::tab {
    background-color: #e1e1e1;
    color: #505050;
    padding: 8px 16px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border: 1px solid #d0d0d0;
    border-bottom: none;
}

QTabBar::tab:selected {
    background-color: #ffffff;
    color: #000000;
    font-weight: bold;
    border-bottom: 2px solid #0078d7;
}

QTabBar::tab:hover:!selected {
    background-color: #f0f0f0;
    color: #000000;
}

QTabBar::close-button {
    image: url(:/icons/close.png);
    background: transparent;
}

QTabBar::close-button:hover {
    background: #c0c0c0;
    border-radius: 2px;
}

/* Кнопки */
QPushButton {
    background-color: #f0f0f0;
    color: #000000;
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    min-width: 60px;
}

QPushButton:hover {
    background-color: #e1e1e1;
    border-color: #c0c0c0;
}

QPushButton:pressed {
    background-color: #d0d0d0;
    border-color: #0078d7;
}

QPushButton:disabled {
    background-color: #f8f8f8;
    color: #a0a0a0;
    border-color: #e0e0e0;
}

/* Текстовое поле вывода */
QTextEdit, QPlainTextEdit {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    font-size: 10pt;
}

/* Полосы прокрутки */
QScrollBar:vertical {
    border: none;
    background-color: #f0f0f0;
    width: 12px;
    margin: 0px;
}

QScrollBar::sub-page:vertical {
    background: #f0f0f0;
}
QScrollBar::add-page:vertical {
    background: #f0f0f0;
}

QScrollBar::handle:vertical {
    background-color: #d0d0d0;
    border-radius: 6px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background-color: #c0c0c0;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}

QScrollBar:horizontal {
    border: none;
    background-color: #f0f0f0;
    height: 12px;
    margin: 0px;
}

QScrollBar::sub-page:horizontal {
    background: #f0f0f0;
}

QScrollBar::add-page:horizontal {
    background: #f0f0f0;
}

QScrollBar::handle:horizontal {
    background-color: #d0d0d0;
    border-radius: 6px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #c0c0c0;
}

/* Тулбар */
QToolBar {
    background-color: #f8f8f8;
    border-bottom: 1px solid #d0d0d0;
    spacing: 3px;
    padding: 3px;
}

QToolButton {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 3px;
}

QToolButton:hover {
    border-color: #d0d0d0;
}

QToolButton:pressed {
    background-color: #d0d0d0;
}

/*Специальные кнопки*/
QToolButton#theme_btn {
    qproperty-icon: url(:/icons/theme_light.png);
    qproperty-iconSize: 20px 20px;
}

QToolButton#add_btn {
    qproperty-icon: url(:/icons/add_light.png);
    qproperty-iconSize: 20px 20px;
}

QToolButton#conf_edit_btn {
    qproperty-icon: url(:/icons/edit_light.png);
    qproperty-iconSize: 17px 17px;
}

QToolButton#tab_autoscroll_btn {
    image: url(:/icons/autoscroll_on_light.png);
    width: 17px;  /* Ширина области иконки */
    height: 17px; /* Высота области иконки */
    padding: 3px;;
}

QToolButton#tab_autoscroll_btn:checked {
    image: url(:/icons/autoscroll_off.png);
}

QToolButton#proj_btn{
    qproperty-icon: url(://icons/open_folder_light.png);
    qproperty-iconSize: 20px 20px;
}

QToolButton#cwd_btn{
    qproperty-icon: url(://icons/open_folder_light.png);
    qproperty-iconSize: 20px 20px;
}

QToolButton#build_btn{
    qproperty-icon: url(://icons/open_file_light.png);
    qproperty-iconSize: 20px 20px;
}

QToolButton#app_btn{
    qproperty-icon: url(://icons/open_file_light.png);
    qproperty-iconSize: 20px 20px;
}

QToolButton#search_btn_n{
    qproperty-icon: url(:/icons/next_light.png);
    qproperty-iconSize: 20px 20px;
}

QToolButton#search_btn_p{
    qproperty-icon: url(:/icons/prev_light.png);
    qproperty-iconSize: 20px 20px;
}

QToolButton#search_btn_h{
    qproperty-icon: url(:/icons/close_search_light.png);
    qproperty-iconSize: 20px 20px;
}

QToolButton[btn_role="stop"]{
    qproperty-icon: url(:/icons/stop_light.png);
    qproperty-iconSize: 23px 23px;
}

QToolButton[btn_role="start"]{
    qproperty-icon: url(:/icons/play_light.png);
    qproperty-iconSize: 23px 23px;
}

QToolButton[btn_role="stop_all"]{
    qproperty-icon: url(:/icons/stop_circle_light.png);
    qproperty-iconSize: 23px 23px;
}

QToolButton[btn_role="clear"]{
    qproperty-icon: url(:/icons/clear_light.png);
    qproperty-iconSize: 23px 23px;
}

QToolButton[btn_role="remove"]{
    qproperty-icon: url(:/icons/remove_light.png);
    qproperty-iconSize: 23px 23px;
}

/* Статус бар */
QStatusBar {
    background-color: #f0f0f0;
    color: #505050;
    border: none;
}

QStatusBar::item {
    border: none;
}

QStatusBar QLabel {
    background-color: transparent;
    color: #505050;
    padding: 3px, 0,0,0;;
    border: none;
}

/* Меню */
QMenuBar {
    background-color: #f8f8f8;
    color: #000000;
    border-bottom: 1px solid #d0d0d0;
}

QMenuBar::item {
    background-color: transparent;
    padding: 4px 8px;
}

QMenuBar::item:selected {
    background-color: #e1e1e1;
}

QMenu {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #d0d0d0;
    padding: 4px;
}

QMenu::item {
    background-color: transparent;
    padding: 6px 24px 6px 30px;
}

QMenu::item:selected {
    background-color: #0078d7;
}

QMenu::separator {
    height: 1px;
    background-color: #d0d0d0;
    margin: 4px 0px;
}

/* Разделители */
QSplitter::handle::vertical {
    image: url(:/icons/splitter_v_light.png);
    height: 1px;
    padding: 2px 0 2px 0;
}

QSplitter::handle::horizontal {
    image: url(:/icons/splitter_h_light.png);
    width: 1px;
    padding: 0 2px 0 2px;
}

/* Список процессов */
QListWidget {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    outline: none;
}

QListWidget::item {
    background-color: transparent;
    color: #000000;
    padding: 0;
    border-radius: 2px;
}

/* Диалоговые окна */
QDialog {
    background-color: #f0f0f0;
    color: #000000;
}

QGroupBox {
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    margin-top: 12px;
    padding-top: 10px;
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 10px;
    padding: 0 5px;
}

/* Поля ввода */
QLineEdit, QComboBox, QSpinBox {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    padding: 5px 8px;
    /*selection-background-color: #0078d7;*/
}

QLineEdit:hover, QComboBox:hover, QSpinBox:hover {
    border-color: #c0c0c0;
}

QLineEdit:focus, QComboBox:focus, QSpinBox:focus {
    border-color: #0078d7;
}

QComboBox::drop-down {
    border: none;
    background: transparent;
}

QComboBox::down-arrow {
    image: url(:/icons/dropdown_light.png);
    width: 12px;
    height: 12px;
}

/* Чекбоксы и радиокнопки */
QCheckBox, QRadioButton {
    color: #000000;
    spacing: 8px;
}

QCheckBox::indicator, QRadioButton::indicator {
    width: 16px;
    height: 16px;
}

QCheckBox::indicator:unchecked {
    image: url(:/icons/checkbox_unchecked_light.png);
}

QCheckBox::indicator:indeterminate  {
    image: url(:/icons/checkbox_partial_light.png);
}

QCheckBox::indicator:checked {
    image: url(:/icons/checkbox_checked_light.png);
}

QRadioButton::indicator:unchecked {
    image: url(:/icons/radio_button_unchecked_light.png);
}

QRadioButton::indicator:checked {
    image: url(:/icons/radio_button_checked_light.png);
}

ConfigurationElementWidget QLabel#drag_handle {
    image: url(:/icons/drager_light.png);
}

ConfigurationElementWidget QLabel#name_lbl[runnable="yes"] {
    color: #206020;
    font-weight: bold
}

ConfigurationElementWidget QLabel#name_lbl[runnable="no"] {
    color: #000000;
    font-weight: normal;
}

/* Индикатор статуса процесса */
#statusIndicator[status="build"] {
    color: #216e8c;
}

#statusIndicator[status="running"] {
    color: #00a000;
}

#statusIndicator[status="error"] {
    color: #a00000;
}

#statusIndicator[status="stop"] {
    color: #ee7b00;
}

#statusIndicator[status="stopped"] {
    color: #000000;
}

#statusIndicator[status="starting"] {
    color: #ffb900;
}

#statusIndicator[status="other"] {
    color: #000000;
}

/* Системный трей */
QSystemTrayIcon {
    /* Настройки для системного трея */
}

/* Tooltip */
QToolTip {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #d0d0d0;
    padding: 5px;
    border-radius: 3px;
    opacity: 240;
}

/* Таблица */
QTableView {
    background-color: #ffffff;
    border: 1px solid #d0d0d0;
    color: #000000;
    gridline-color: #d0d0d0;
    /*selection-background-color: #0078d7;
    selection-color: #ffffff;*/
    alternate-background-color: #f8f8f8;
}

QTableView::item {
    padding: 1px;
    border: none;
}

/*QTableView::item:selected {
    background-color: #0078d7;
    color: #ffffff;
}*/

QHeaderView {
    background-color: #f0f0f0;
    border: none;
}

QHeaderView::section {
    background-color: #f0f0f0;
    color: #000000;
    padding: 0;
    border: 1px solid #d0d0d0;
}

/* Прогресс бар */
QProgressBar {
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    background-color: #ffffff;
    text-align: center;
    color: #000000;
}

QProgressBar::chunk {
    background-color: #0078d7;
    border-radius: 2px;
}

/* Дерево */
QTreeView {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    outline: none;
}

QTreeView::item {
    padding: 5px;
}

QTreeView::item:selected {
    background-color: #0078d7;
    color: #ffffff;
}

QTreeView::item:hover:!selected {
    background-color: #f0f0f0;
}

/* Заголовки */
QLabel {
    color: #000000;
}

QLabel[type="title"] {
    font-size: 14pt;
    font-weight: bold;
    color: #000000;
}

QLabel[type="subtitle"] {
    font-size: 12pt;
    color: #505050;
}

/* Специальные стили для ProcessTab */
ProcessTab {
    background-color: #ffffff;
}

ProcessTab QTextEdit#tab_logs {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10pt;
    line-height: 1.2;
    selection-background-color: #00896c;
    selection-color: white;
}

/* Дополнительные стили для лучшего контраста */
QToolBar QToolButton {
    border: 1px solid transparent;
}

QToolBar QToolButton:hover {
    border: 1px solid #c0c0c0;
}

QToolBar QToolButton:pressed {
    border: 1px solid #0078d7;
}

/* Стили для неактивных элементов */
QWidget:disabled {
    color: #a0a0a0;
}

/* Разделительные линии */
QFrame[class="separatorLine"] {
    background-color: #d0d0d0;
    max-height: 1px;
    border: none;
}
